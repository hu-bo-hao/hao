:root {
  --primary-purple: #7C3AED;
  --warm-orange: #F97316;
  --light-purple-bg: #F3E8FF;
  --card-white: #FFFFFF;
  --text-dark: #1E1B2C;
  --text-secondary: #6C5A7A;
}

page {
  background: linear-gradient(145deg, #F8F0FF 0%, #F3E8FF 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  opacity: 0;
  animation: pageFadeIn 0.5s ease forwards;
}

@keyframes pageFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.card {
  background: var(--card-white);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(124, 58, 237, 0.08);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 48rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-purple) 0%, #A855F7 100%);
  color: var(--card-white);
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.2);
}

.btn-secondary {
  background: var(--card-white);
  color: var(--primary-purple);
  border: 2rpx solid var(--primary-purple);
}

.btn-secondary:active {
  background: var(--light-purple-bg);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-dark);
  text-align: center;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: 16rpx;
}
