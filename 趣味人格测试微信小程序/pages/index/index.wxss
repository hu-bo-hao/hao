.header {
  padding: 40rpx 0 60rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1E1B2C;
  text-align: center;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #6C5A7A;
  text-align: center;
  margin-top: 20rpx;
  display: block;
  padding: 0 40rpx;
}

.test-list {
  margin-top: 20rpx;
}

.test-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.test-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(124, 58, 237, 0.08);
}

.card-icon {
  font-size: 80rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E1B2C;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6C5A7A;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.question-count {
  font-size: 24rpx;
  color: #7C3AED;
  background: #F3E8FF;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.arrow {
  font-size: 32rpx;
  color: #7C3AED;
  font-weight: 600;
}

.footer {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.footer-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
}
