.result-header {
  padding: 40rpx 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E1B2C;
  text-align: center;
  display: block;
}

.result-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #7C3AED 0%, #F97316 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.desc-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E1B2C;
  margin-bottom: 24rpx;
  display: block;
}

.desc-text {
  font-size: 28rpx;
  color: #6C5A7A;
  line-height: 1.8;
  display: block;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 48rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #7C3AED 0%, #A855F7 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(124, 58, 237, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.2);
}

.btn-secondary {
  background: #F9F6FE;
  color: #7C3AED;
  border: 2rpx solid #EDE9FE;
}

.btn-secondary:active {
  background: #F3E8FF;
}

.btn-outline {
  background: #FFFFFF;
  color: #7C3AED;
  border: 2rpx solid #7C3AED;
}

.btn-outline:active {
  background: #F3E8FF;
}

.share-canvas {
  position: fixed;
  left: -1000rpx;
  top: -1000rpx;
  width: 600rpx;
  height: 800rpx;
}
