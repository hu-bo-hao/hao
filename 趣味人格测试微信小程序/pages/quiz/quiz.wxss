.theme-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E1B2C;
  text-align: center;
  margin-bottom: 32rpx;
  padding-top: 20rpx;
}

.progress-section {
  margin-bottom: 40rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #6C5A7A;
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 16rpx;
  background: #EDE9FE;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7C3AED 0%, #F97316 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.question-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.1);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.question-card.fade-out {
  opacity: 0.5;
  transform: translateX(-20rpx);
}

.question-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E1B2C;
  line-height: 1.6;
  display: block;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  background: #F9F6FE;
  border-radius: 60rpx;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #EDE9FE;
  transition: all 0.2s ease;
}

.option-item:active {
  background: #F3E8FF;
  border-color: #7C3AED;
  transform: scale(0.98) translateX(10rpx);
}

.option-indicator {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #A855F7 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 30rpx;
  color: #1E1B2C;
  line-height: 1.4;
  flex: 1;
}

.tip-section {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
  display: block;
}
